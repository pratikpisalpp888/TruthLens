# Database Setup (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://truthlens:truthlens123@localhost:5432/truthlens
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=truthlens
DATABASE_PASSWORD=truthlens123
DATABASE_NAME=truthlens

# Qdrant Vector DB Setup
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_MODE=persistent
QDRANT_PATH=./qdrant_data

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage

# MinIO Config (Used only if STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=truthlens
MINIO_SECRET_KEY=truthlens123
MINIO_BUCKET=documents
